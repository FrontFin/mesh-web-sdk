{
  "name": "@meshconnect/mesh-b2b-sdk",
  "version": "2.0.3",
  "description": "Mesh Connect JS SDKs",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^7.23.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.4.0",
    "lerna": "^9.0.7",
    "prettier": "^2.2.1",
    "rimraf": "^5.0.10",
    "typescript": "^5.0.4",
    "yarn": "^1.22.19"
  },
  "scripts": {
    "typecheck": "lerna run typecheck",
    "lint": "lerna run lint",
    "build": "lerna run build",
    "test": "lerna run test",
    "test:updateSnapshots": "lerna run test -- -u",
    "test:cov": "lerna run test:cov",
    "lint:fix": "lerna run lint -- --fix",
    "start:demo": "cd examples/react-example && yarn start",
    "updateApi": "cd packages/node-api && yarn updateApi",
    "publish:npm": "lerna run publish:npm",
    "postinstall": "cd packages/link && yarn updateVersion"
  },
  "resolutions": {
    "@typescript-eslint/**/brace-expansion": "2.0.3",
    "@typescript-eslint/**/minimatch": "9.0.9",
    "flatted": "3.4.2",
    "handlebars": "4.7.9",
    "axios": "^1.16.0",
    "bn.js": "5.2.3",
    "esbuild": "^0.25.0",
    "vite": "^6.4.2",
    "rollup": "^4.59.0",
    "postcss": "^8.5.10",
    "nanoid": "^3.3.12",
    "lodash": "^4.17.24",
    "fast-uri": "^3.1.2",
    "follow-redirects": "^1.16.0",
    "ip-address": "^10.1.1",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "@tootallnate/once": "^2.0.1",
    "form-data": "^4.0.6",
    "tmp": "^0.2.6",
    "tar": "^7.5.16"
  }
}
